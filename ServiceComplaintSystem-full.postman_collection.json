{
  "info": {
    "name": "Service Complaint System - Full API",
    "description": "Complete Postman collection for authentication and complaint management routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "complaintId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Durvankur\",\n  \"email\": \"durvankur@gmail.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"durvankur@gmail.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Noise complaint in building\",\n  \"description\": \"Loud music every night after 10 PM.\",\n  \"status\": \"OPEN\",\n  \"priority\": \"MEDIUM\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/complaints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints"
              ]
            }
          }
        },
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/complaints?page=0&size=10&sortBy=id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                }
              ]
            }
          }
        },
        {
          "name": "Count Complaints by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/complaints/count?status=OPEN",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints",
                "count"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "OPEN"
                }
              ]
            }
          }
        },
        {
          "name": "Get Complaint by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/complaints/{{complaintId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints",
                "{{complaintId}}"
              ]
            }
          }
        },
        {
          "name": "Update Complaint",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Noise complaint update\",\n  \"description\": \"Loud music every night after 10 PM. Neighbors filed a second complaint.\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"HIGH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/complaints/{{complaintId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints",
                "{{complaintId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Complaint",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/complaints/{{complaintId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "complaints",
                "{{complaintId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
